# ─────────────────────────────────────────────────────────────
#  Hercules Mainframe Simulator — environment configuration
#
#  Copy this file to .env and fill in your values.
#  .env is gitignored and never committed.
# ─────────────────────────────────────────────────────────────

# ─── DB2 (local Docker) ───────────────────────────────────────
# Password for the db2inst1 user inside the DB2 container.
# Must match between the db2 and backend services.
DB2_PASSWORD=H3rcules_change_me

# ─── App authentication ───────────────────────────────────────
# Password required at the ISPF login screen.
# Leave empty to accept any password (open dev mode).
DEMO_PASSWORD=

# ─── Vercel deployment (used by scripts/deploy.sh) ────────────
# Personal access token: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Project IDs — found in .vercel/project.json after `vercel link`
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
